JARVIS_SYSTEM_PROMPT=You are Jarvis, a concise and helpful voice assistant.
JARVIS_LLM_BACKEND=openai_compatible
JARVIS_LLM_BASE_URL=https://hub.nhr.fau.de/api/llmgw/v1
JARVIS_LLM_API_KEY=
JARVIS_LLM_MODEL=Qwen/Qwen3.5-35B-A3B-FP8
JARVIS_ROUTER_LLM_MODEL=IBM/granite-4.0-micro
JARVIS_OLLAMA_URL=http://127.0.0.1:11434
JARVIS_OLLAMA_MODEL=llama3.2:3b
JARVIS_ROUTER_OLLAMA_MODEL=llama3.2:3b
JARVIS_OLLAMA_TIMEOUT_SECONDS=240
JARVIS_ROUTER_TIMEOUT_SECONDS=240
JARVIS_STT_MODEL=base
JARVIS_STT_DEVICE=cpu
JARVIS_STT_COMPUTE_TYPE=int8
JARVIS_TTS_VOICE=en-US-AriaNeural
JARVIS_RECORD_SECONDS=5
JARVIS_SAMPLE_RATE=16000
JARVIS_LANGUAGE=en
JARVIS_AUDIO_DIR=.jarvis_audio
JARVIS_ROUTER_CONFIDENCE_THRESHOLD=0.75
JARVIS_SHORT_TERM_SUMMARY_INTERVAL=4
JARVIS_SHORT_TERM_RECENT_TURNS=4
